@import "tailwindcss";

:root {
  --bg: #f6f0e7;
  --paper: #fffaf2;
  --ink: #1e2a25;
  --muted: #6b756f;
  --green: #1f5f4a;
  --green-dark: #164334;
  --sand: #dfc9a6;
  --line: #e5dccd;
  --danger: #9f2d20;
}

* { box-sizing: border-box; }

body {
  margin: 0;
  background: radial-gradient(circle at top left, #fff7ea 0, var(--bg) 34%, #ece2d2 100%);
  color: var(--ink);
  font-family: Arial, Helvetica, sans-serif;
}

a { color: inherit; text-decoration: none; }
button, input, textarea, select { font: inherit; }

.container { max-width: 1180px; margin: 0 auto; padding: 32px 20px 80px; }
.topbar { display: flex; justify-content: space-between; gap: 16px; align-items: center; margin-bottom: 24px; }
.brand { display: flex; flex-direction: column; gap: 3px; }
.kicker { font-size: 12px; letter-spacing: .12em; text-transform: uppercase; color: var(--green); font-weight: 700; }
h1 { font-size: clamp(34px, 6vw, 64px); line-height: .95; margin: 0; letter-spacing: -0.04em; }
h2 { margin: 0 0 10px; font-size: 26px; letter-spacing: -0.02em; }
h3 { margin: 0 0 8px; font-size: 18px; }
p { color: var(--muted); line-height: 1.6; }

.card {
  background: rgba(255, 250, 242, 0.92);
  border: 1px solid var(--line);
  border-radius: 28px;
  padding: 24px;
  box-shadow: 0 18px 50px rgba(31, 42, 37, 0.08);
}
.grid { display: grid; gap: 18px; }
.grid-2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
.grid-3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }
@media (max-width: 850px) { .grid-2, .grid-3 { grid-template-columns: 1fr; } }

.button, .button-secondary, .button-danger {
  display: inline-flex; align-items: center; justify-content: center; gap: 8px;
  border-radius: 999px; padding: 12px 18px; border: 0; cursor: pointer;
  font-weight: 700; transition: transform .15s ease, opacity .15s ease;
}
.button:hover, .button-secondary:hover { transform: translateY(-1px); }
.button { background: var(--green); color: white; }
.button-secondary { background: white; color: var(--green-dark); border: 1px solid var(--line); }
.button-danger { background: #fff0ee; color: var(--danger); border: 1px solid #f0c7c0; }
.button:disabled, .button-secondary:disabled { opacity: .55; cursor: wait; }

.input, .textarea, .select {
  width: 100%; border: 1px solid var(--line); background: white; color: var(--ink);
  border-radius: 18px; padding: 12px 14px; outline: none;
}
.textarea { min-height: 96px; resize: vertical; }
.label { display: grid; gap: 8px; font-weight: 700; color: #34423a; }
.help { font-size: 13px; color: var(--muted); }
.badge { display: inline-flex; align-items: center; border-radius: 999px; padding: 6px 10px; background: #e8f1eb; color: var(--green-dark); font-size: 12px; font-weight: 700; }
.badge-soft { background: #f3eadb; color: #7b5522; }
.error { background: #fff0ee; color: var(--danger); border: 1px solid #e7b2aa; border-radius: 18px; padding: 14px; }
.success { background: #edf8f1; color: var(--green-dark); border: 1px solid #c7e3d0; border-radius: 18px; padding: 14px; }

.project-card { display: block; min-height: 190px; }
.project-card:hover { border-color: #b9c9bf; }
.meta { display: flex; gap: 8px; flex-wrap: wrap; margin: 12px 0; }
.photo-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 14px; }
.photo-card { overflow: hidden; border-radius: 22px; border: 1px solid var(--line); background: white; }
.photo-card img { width: 100%; height: 150px; object-fit: cover; display: block; }
.photo-card .body { padding: 12px; }
.workflow { display: grid; grid-template-columns: repeat(5, minmax(0, 1fr)); gap: 10px; }
@media (max-width: 900px) { .workflow { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
.step { padding: 12px; border-radius: 18px; background: white; border: 1px solid var(--line); color: var(--muted); }
.step.done { background: #e9f3ed; color: var(--green-dark); border-color: #bcd9c7; }
.step strong { display: block; color: var(--ink); margin-bottom: 4px; }
.columns { display: grid; grid-template-columns: 1fr 340px; gap: 18px; align-items: start; }
@media (max-width: 980px) { .columns { grid-template-columns: 1fr; } }
ul.clean { margin: 8px 0 0; padding-left: 20px; color: var(--muted); line-height: 1.55; }
pre.json { white-space: pre-wrap; word-break: break-word; background: #1e2a25; color: #edf8f1; padding: 18px; border-radius: 18px; font-size: 13px; }
.divider { height: 1px; background: var(--line); margin: 18px 0; }

.project-header { align-items: flex-start; }
.quick-actions { min-width: min(100%, 620px); }
.actions-row { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 12px; }
.actions-row > div { display: inline-flex; }
.compact-card { box-shadow: none; border-radius: 20px; padding: 16px; }
.benchmark-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 16px; }
.reference-card { overflow: hidden; border: 1px solid var(--line); border-radius: 24px; background: white; box-shadow: 0 12px 32px rgba(31, 42, 37, 0.06); }
.reference-card img { width: 100%; height: 185px; object-fit: cover; display: block; background: #e8dcc9; }
.reference-card .body { padding: 16px; }
.svg-frame { width: 100%; overflow: hidden; border: 1px solid var(--line); border-radius: 24px; background: white; box-shadow: 0 12px 32px rgba(31, 42, 37, 0.06); }
.svg-frame svg { display: block; width: 100%; height: auto; }
.prompt-box { margin-top: 16px; padding: 16px; border: 1px solid var(--line); border-radius: 18px; background: white; }
.sticky-aside { position: sticky; top: 18px; }
@media (max-width: 980px) { .sticky-aside { position: static; } .quick-actions { min-width: 100%; } }
